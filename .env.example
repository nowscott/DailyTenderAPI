# Optional fallbacks. iOS Shortcuts can also send these as query parameters.
PORT=3000
TIME_ZONE=Asia/Shanghai

# Prefer passing names in the request so the API is reusable and not hardcoded.
PERSON1_NAME=
PERSON2_NAME=

# Format: YYYY-MM-DD
LOVE_START_DATE=

# Format: MM-DD
PERSON1_BIRTHDAY=
PERSON2_BIRTHDAY=

# Optional: iciba or local. The message endpoint defaults to iciba with local fallback.
QUOTE_SOURCE=iciba
